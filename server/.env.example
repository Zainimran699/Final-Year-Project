# Supabase Postgres connection strings
# Get these from: Supabase dashboard → Project Settings → Database → Connection string
# DATABASE_URL = Transaction pooler (port 6543), used at runtime
# DIRECT_URL   = Direct connection (port 5432), used by Prisma migrations
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Random long string used to sign JWTs
JWT_SECRET=replace_me_with_a_long_random_string

# Google Gemini API key (free tier) — get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Express port (5000 is taken by macOS AirPlay Receiver — using 5001)
PORT=5001

# SMTP settings for OTP emails (signup verification + password reset).
# If SMTP_HOST is not set, OTPs are logged to the server console instead.
# For Gmail: use smtp.gmail.com, port 587, and generate an App Password at
# https://myaccount.google.com/apppasswords (2FA must be enabled).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=DriveReady221 <your_gmail@gmail.com>
